# Google AI Studio API key (Gemini): https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Where ZIP uploads and git clones are stored (default: F:/ai_se_assistant_data)
# ASSISTANT_DATA_DIR=F:/my_custom_folder

# Optional: embedding model for RAG (default in code is gemini-embedding-001)
# EMBEDDING_MODEL=gemini-embedding-001

